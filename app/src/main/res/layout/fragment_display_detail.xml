<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <!-- Quick Actions -->
        <TextView
            android:id="@+id/actions_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/actions_header"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?colorPrimary"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/start_launcher_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/cast_single_app" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/touchpad_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:text="@string/touchpad" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/touchscreen_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:text="@string/source_touchscreen" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/managed_virtual_display_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:text="@string/managed_virtual_display_button_text"
                style="@style/Widget.Material3.Button.TonalButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/reset_config_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:text="@string/reset_display_config"
                style="@style/Widget.Material3.Button.TonalButton" />
        </LinearLayout>

        <!-- Display Settings -->
        <TextView
            android:id="@+id/settings_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?colorPrimary"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/settings_section"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Auto-open last app -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/auto_open_last_app"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/auto_open_last_app_desc"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?colorOnSurfaceVariant"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/autoOpenLastAppSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Floating button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/floating_button"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/floating_button_desc"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?colorOnSurfaceVariant"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/floating_button_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Floating button: force landscape -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/floating_button_force_landscape"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/floating_button_force_landscape_desc"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?colorOnSurfaceVariant"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/floating_button_force_landscape_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- On-screen keyboard location -->
            <LinearLayout
                android:id="@+id/ime_policy_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:minHeight="56dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ime_to_this_display"
                        android:textAppearance="?attr/textAppearanceBodyLarge" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ime_to_this_display_desc"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?colorOnSurfaceVariant"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
                <Spinner
                    android:id="@+id/ime_policy_spinner"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="160dp" />
            </LinearLayout>

        </LinearLayout>

        <!-- Display Configuration -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/display_config_header"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?colorPrimary"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="?selectableItemBackground">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/resolution_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:id="@+id/resolution_text"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant" />
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/edit_resolution_button"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/edit" android:visibility="gone"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/scale_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:visibility="gone"
            android:background="?selectableItemBackground">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/scale_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:id="@+id/scale_text"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant" />
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/edit_scale_button"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/edit"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/scale_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:visibility="gone"
            android:valueFrom="50"
            android:valueTo="400"
            android:stepSize="5" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="?selectableItemBackground">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/dpi_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:id="@+id/dpi_text"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant" />
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/edit_dpi_button"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/edit" android:visibility="gone"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <com.google.android.material.slider.Slider
            android:id="@+id/dpi_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:visibility="gone"
            android:valueFrom="100"
            android:valueTo="640"
            android:stepSize="10" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="?selectableItemBackground">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/rotation_label"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:id="@+id/user_rotation_text"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant" />
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/edit_rotation_button"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="@string/edit" android:visibility="gone"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <!-- Display Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/display_info_header"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?colorPrimary"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:id="@+id/info_table"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- Advanced -->
        <TextView
            android:id="@+id/shizuku_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/advanced_info_header"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?colorPrimary"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:id="@+id/shizuku_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <LinearLayout
                android:id="@+id/shizuku_table"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Supported display modes -->
        <TextView
            android:id="@+id/supported_modes_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/supported_modes_header"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?colorPrimary"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:id="@+id/modes_table"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</ScrollView>
