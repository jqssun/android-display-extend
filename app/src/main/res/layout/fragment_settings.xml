<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <!-- Application category -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_application"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?colorPrimary"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <TextView
            android:id="@+id/trackingSpeedLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:text="@string/tracking_speed"
            android:textAppearance="?attr/textAppearanceBodyLarge" />

        <com.google.android.material.slider.Slider
            android:id="@+id/trackingSpeedSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:valueFrom="0.5"
            android:valueTo="3.0"
            android:stepSize="0.1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/show_system_setting_names"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/show_system_setting_names_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/showSystemSettingNamesSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Display category -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_displays"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?colorPrimary"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <!-- Disable USB audio -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/disableUsbAudioTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/disable_usb_audio"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/disable_usb_audio_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/disableUsbAudioCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Match content frame rate -->
        <LinearLayout
            android:id="@+id/matchContentFrameRateRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/matchContentFrameRateTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/match_content_frame_rate"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/match_content_frame_rate_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <Spinner
                android:id="@+id/matchContentFrameRateSpinner"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="160dp" />
        </LinearLayout>

        <!-- Force desktop mode -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/forceDesktopTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/force_desktop_mode"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/force_desktop_mode_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/forceDesktopCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Force resizable -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/forceResizableTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/force_resizable"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/force_resizable_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/forceResizableCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Enable freeform -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/enableFreeformTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/enable_freeform"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/enable_freeform_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/enableFreeformCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Non-resizable multi-window -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/enableNonResizableTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/enable_non_resizable_multiwindow"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/enable_non_resizable_multiwindow_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/enableNonResizableCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Disable screen share protection -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/disableScreenShareProtectionTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/disable_screen_share_protection"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/disable_screen_share_protection_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/disableScreenShareProtectionCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Power category -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_power"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?colorPrimary"
            android:paddingHorizontal="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="4dp" />

        <!-- Stay on while plugged -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView
                    android:id="@+id/stayOnWhilePluggedTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/stay_on_while_plugged"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/stay_on_while_plugged_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/stayOnWhilePluggedCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Real screen off -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/use_real_screen_off"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/use_real_screen_off_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/useRealScreenOffCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Auto screen off -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:minHeight="56dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/auto_screen_off"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/auto_screen_off_desc"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorOnSurfaceVariant"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/autoScreenOffCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/resetAllBtn"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:text="@string/reset_all_settings" />

        <!-- About -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/aboutCard"
            style="@style/Widget.Material3.CardView.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/versionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="?attr/textAppearanceBodyLarge" />

                <TextView
                    android:id="@+id/websiteLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/website_label"
                    android:textAppearance="?attr/textAppearanceBodyMedium"
                    android:textColor="?colorPrimary" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/shizukuBtn"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/shizuku" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/exitBtn"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/exit" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
