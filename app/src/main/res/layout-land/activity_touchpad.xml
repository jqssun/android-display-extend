<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="horizontal">

    <!-- Touchpad + scroll strip -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_margin="16dp">

        <TextView
            android:id="@+id/touchpad_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="32dp"
            android:background="@drawable/touchpad_background"
            android:clickable="true"
            android:focusable="true"
            android:textColor="?colorOnSurfaceVariant"
            android:lineSpacingExtra="8dp"
            android:gravity="top" />

        <View
            android:id="@+id/scrollStrip"
            android:layout_width="24dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:background="@drawable/scroll_track_background" />
    </LinearLayout>

    <!-- Side action buttons -->
    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:paddingVertical="16dp"
        android:paddingEnd="16dp"
        android:orientation="vertical"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_back"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:contentDescription="@string/back_button"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/homeButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_home"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:contentDescription="@string/home_button"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/displayOffButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_screen_off"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:contentDescription="@string/display_off_button"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rotateButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_rotate"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:contentDescription="@string/rotate"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rotateCwButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_rotate_cw"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            android:contentDescription="@string/rotate_cw"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />
    </LinearLayout>

    <!-- Hidden views referenced by code but not shown in landscape -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/switchModeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/modeSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/exitButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
