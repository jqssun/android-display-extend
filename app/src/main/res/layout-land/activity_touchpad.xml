<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/touchpadRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:orientation="horizontal">

    <!-- Touchpad + scroll strip -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_margin="16dp">

        <LinearLayout
            android:id="@+id/touchpad_area"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="24dp"
            android:background="@drawable/touchpad_background"
            android:orientation="vertical">

            <TextView
                android:id="@+id/touchpad_gesture_hint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?colorOnSurfaceVariant" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/touchpad_button_hints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="bottom">

                <include layout="@layout/touchpad_hint_row"
                    android:id="@+id/hint_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp" />

                <include layout="@layout/touchpad_hint_row"
                    android:id="@+id/hint_home"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp" />

                <include layout="@layout/touchpad_hint_row"
                    android:id="@+id/hint_night_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp" />

                <include layout="@layout/touchpad_hint_row"
                    android:id="@+id/hint_rotate_ccw"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp" />

                <include layout="@layout/touchpad_hint_row"
                    android:id="@+id/hint_rotate_cw"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:id="@+id/scrollStrip"
            android:layout_width="24dp"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:background="@drawable/scroll_track_background" />
    </LinearLayout>

    <!-- Side action buttons -->
    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:paddingVertical="16dp"
        android:paddingEnd="16dp"
        android:orientation="vertical"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_back"
            app:iconGravity="textStart"
            android:contentDescription="@string/back_button"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/homeButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_home"
            app:iconGravity="textStart"
            android:contentDescription="@string/home_button"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nightModeButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_night_mode"
            app:iconGravity="textStart"
            android:contentDescription="@string/touchpad_hint_night_mode"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rotateCcwButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_rotate"
            app:iconGravity="textStart"
            android:contentDescription="@string/rotate"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/rotateCwButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="8dp"
            app:icon="@drawable/ic_rotate_cw"
            app:iconGravity="textStart"
            android:contentDescription="@string/rotate_cw"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />
    </LinearLayout>

    <!-- Hidden views referenced by code but not shown in landscape -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/switchModeButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <Spinner
            android:id="@+id/modeSpinner"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/exitButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
